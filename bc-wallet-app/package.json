{
  "name": "bc-wallet-app",
  "version": "1.0.0",
  "private": true,
  "description": "BC Wallet — Multi-chain HD Wallet app (React / Expo)",

  "main": "index.js",

  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",

    "build": "expo export --platform web",

    "api": "node ../mini-blockchain/api/server.js",
    "api:bc": "node ../mini-blockchain/api/server.js & node ../mini-blockchain/blockchain/blockchain.js",

    "dev": "concurrently \"npm run api\" \"npm run web\"",

    "lint": "eslint src --ext .ts,.tsx,.js,.jsx"
  },

  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",

    "react": "18.2.0",
    "react-dom": "18.2.0",

    "react-native": "0.74.5",
    "react-native-web": "~0.19.10",

    "react-native-reanimated": "~3.10.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",

    "expo-status-bar": "~1.12.1",
    "expo-clipboard": "~6.0.3",
    "expo-haptics": "~13.0.1",
    "expo-blur": "~13.0.2",
    "expo-linear-gradient": "~13.0.2",
    "expo-secure-store": "~13.0.2",
    "expo-local-authentication": "~14.0.1",

    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",

    "nativewind": "^4.0.1",
    "tailwindcss": "^3.4.0",

    "react-native-qrcode-svg": "^6.3.2",
    "react-native-svg": "15.2.0",

    "zustand": "^4.5.2",
    "swr": "^2.2.5"
  },

  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "^5.3.3",
    "eslint": "^8.57.0",
    "concurrently": "^8.2.2"
  }
}
